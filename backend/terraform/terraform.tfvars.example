project_id       = "your-gcp-project-id"
region           = "us-central1"
gke_cluster_name = "crypto-compliance-gke"
gke_location     = "us-central1-a"

namespace        = "crypto-compliance"
create_namespace = true

app_name = "crypto-compliance-backend"
image    = "ghcr.io/your-org/crypto-compliance-backend:latest"
replicas = 2

service_type = "ClusterIP"
service_port = 80

postgres_instance_name = "crypto-compliance-postgres"
postgres_db            = "compliance"
postgres_user          = "compliance"
postgres_password      = "change-me"

valkey_instance_id = "crypto-compliance-valkey"
valkey_location    = "us-central1"

policy_hmac_secret = "change-me"

env = {
  # Optional overrides. Defaults for PORT, COMPLIANCE_DB_*, and
  # COMPLIANCE_VALKEY_* are auto-generated from GCP data lookups.
}
