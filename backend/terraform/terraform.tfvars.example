project_id       = "your-gcp-project-id"
region           = "us-central1"
root_state_bucket = "vernal-parser-328009-crypto-compliance-tfstate-prod"
root_state_prefix = "crypto-compliance/prod/root"

namespace        = "crypto-compliance"
create_namespace = true

app_name = "crypto-compliance-backend"
image    = "ghcr.io/your-org/crypto-compliance-backend:latest"
replicas = 2

service_type = "ClusterIP"
service_port = 80

# Ingress is always created.
# HTTP health checks are pinned to /healthz via BackendConfig.
# A separate gRPC Service LoadBalancer is also created on port 50051.
# ingress_class_name = "gce"
# ingress_host       = "api.example.com"
# ingress_path       = "/"
# ingress_path_type  = "Prefix"
# ingress_annotations = {
#   "kubernetes.io/ingress.global-static-ip-name" = "crypto-compliance-backend-ip"
# }

postgres_password = "change-me"

policy_hmac_secret = "change-me"

env = {
  # Optional overrides. Defaults for PORT, COMPLIANCE_DB_*, and
  # COMPLIANCE_VALKEY_* come from root Terraform remote-state outputs.
}
