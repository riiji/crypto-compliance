project_id       = "your-gcp-project-id"
region           = "us-central1"
root_state_bucket = "vernal-parser-328009-crypto-compliance-tfstate-prod"
root_state_prefix = "crypto-compliance/prod/root"

namespace        = "crypto-compliance"
create_namespace = true

app_name = "crypto-compliance-backend"
image    = "ghcr.io/your-org/crypto-compliance-backend:latest"
replicas = 2

# Set to LoadBalancer if you want direct external gRPC access.
service_type = "ClusterIP"

postgres_password = "change-me"
compliance_api_url = "https://api.example.com/v1/compliance-check"

policy_hmac_secret = "change-me"
internal_hmac_secret = "change-me"

env = {
  # Optional overrides. Defaults for COMPLIANCE_GRPC_PORT, COMPLIANCE_DB_*, and
  # COMPLIANCE_VALKEY_* come from root Terraform remote-state outputs.
}
